rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' ||
          (request.auth.token.email == "cv1@gmx.ch"));
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function ownerIdUnchanged() {
      return !('ownerId' in request.resource.data) || request.resource.data.ownerId == request.auth.uid;
    }
    
    function ownerIdNotModified() {
      return !('ownerId' in request.resource.data) || request.resource.data.ownerId == resource.data.ownerId;
    }

    function senderIdUnchanged() {
      return !('senderId' in request.resource.data) || request.resource.data.senderId == request.auth.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 150 &&
             data.role in ["Admin", "Internal", "External Planner", "Client"] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('department' in data) || (data.department is string && data.department.size() < 100)) &&
             (!('hourlyRate' in data) || data.hourlyRate is number) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 1000)) &&
             (!('trialEndsAt' in data) || (data.trialEndsAt is string && data.trialEndsAt.size() < 50)) &&
             (!('hasActiveSubscription' in data) || data.hasActiveSubscription is bool) &&
             (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() < 50));
    }

    function isValidProject(data) {
      return data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.status in ["active", "completed", "on-hold", "planning"] &&
             data.ownerId is string && data.ownerId.size() > 0 && data.ownerId.size() < 100 &&
             (!('description' in data) || (data.description is string && data.description.size() < 2000)) &&
             (!('role' in data) || (data.role in ["owner", "admin", "viewer"])) &&
             (!('client' in data) || (data.client is string && data.client.size() < 100)) &&
             (!('budget' in data) || data.budget is number) &&
             (!('spent' in data) || data.spent is number) &&
             (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() < 50)) &&
             (!('dueDate' in data) || (data.dueDate is string && data.dueDate.size() < 50));
    }

    function isValidTransaction(data) {
      return data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.projectId is string && data.projectId.size() > 0 && data.projectId.size() < 100 &&
             data.date is string && data.date.size() > 0 && data.date.size() < 50 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 500 &&
             data.amount is number &&
             data.status in ["Completed", "Pending", "Failed"] &&
             data.ownerId is string && data.ownerId.size() > 0 && data.ownerId.size() < 100 &&
             (!('category' in data) || (data.category is string && data.category.size() < 100));
    }

    function isValidEvent(data) {
      return data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.date is string && data.date.size() > 0 && data.date.size() < 50 &&
             data.ownerId is string && data.ownerId.size() > 0 && data.ownerId.size() < 100 &&
             (!('time' in data) || (data.time is string && data.time.size() < 50)) &&
             (!('type' in data) || (data.type is string && data.type.size() < 100)) &&
             (!('description' in data) || (data.description is string && data.description.size() < 1000)) &&
             (!('projectId' in data) || (data.projectId is string && data.projectId.size() < 100));
    }

    function isValidDefect(data) {
      return data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.status in ["To Do", "In Progress", "In Review", "Done"] &&
             data.priority in ["Low", "Medium", "High", "Critical"] &&
             data.ownerId is string && data.ownerId.size() > 0 && data.ownerId.size() < 100 &&
             (!('description' in data) || (data.description is string && data.description.size() < 2000)) &&
             (!('assignee' in data) || (data.assignee is string && data.assignee.size() < 100)) &&
             (!('trade' in data) || (data.trade is string && data.trade.size() < 100)) &&
             (!('location' in data) || (data.location is string && data.location.size() < 200)) &&
             (!('date' in data) || (data.date is string && data.date.size() < 50)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 1000)) &&
             (!('dueDate' in data) || (data.dueDate is string && data.dueDate.size() < 50)) &&
             (!('projectId' in data) || (data.projectId is string && data.projectId.size() < 100));
    }

    function isValidWhiteboardElement(data) {
      return data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.type in ["rectangle", "circle", "text", "line"] &&
             data.x is number &&
             data.y is number &&
             data.ownerId is string && data.ownerId.size() > 0 && data.ownerId.size() < 100 &&
             (!('width' in data) || data.width is number) &&
             (!('height' in data) || data.height is number) &&
             (!('color' in data) || (data.color is string && data.color.size() < 50)) &&
             (!('text' in data) || (data.text is string && data.text.size() < 1000)) &&
             (!('projectId' in data) || (data.projectId is string && data.projectId.size() < 100));
    }

    function isValidChatMessage(data) {
      return data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 2000 &&
             data.senderId is string && data.senderId.size() > 0 && data.senderId.size() < 100 &&
             data.timestamp is number &&
             data.projectId is string && data.projectId.size() > 0 && data.projectId.size() < 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields(['uid', 'email', 'role']) && isValidUser(request.resource.data) && uidUnchanged() && ((isOwner(userId) && request.resource.data.role == 'Internal') || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && uidNotModified() && ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields(['id', 'name', 'status', 'ownerId']) && isValidProject(request.resource.data) && ownerIdUnchanged();
      allow update: if isAuthenticated() && isValidProject(request.resource.data) && ownerIdNotModified() && (isDocOwner() || isAdmin());
      allow delete: if isDocOwner() || isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields(['id', 'projectId', 'date', 'description', 'amount', 'status', 'ownerId']) && isValidTransaction(request.resource.data) && ownerIdUnchanged();
      allow update: if isAuthenticated() && isValidTransaction(request.resource.data) && ownerIdNotModified() && (isDocOwner() || isAdmin());
      allow delete: if isDocOwner() || isAdmin();
    }

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields(['id', 'title', 'date', 'ownerId']) && isValidEvent(request.resource.data) && ownerIdUnchanged();
      allow update: if isAuthenticated() && isValidEvent(request.resource.data) && ownerIdNotModified() && (isDocOwner() || isAdmin());
      allow delete: if isDocOwner() || isAdmin();
    }

    match /defects/{defectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields(['id', 'title', 'status', 'priority', 'ownerId']) && isValidDefect(request.resource.data) && ownerIdUnchanged();
      allow update: if isAuthenticated() && isValidDefect(request.resource.data) && ownerIdNotModified() && (isDocOwner() || isAdmin());
      allow delete: if isDocOwner() || isAdmin();
    }

    match /whiteboardElements/{elementId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields(['id', 'type', 'x', 'y', 'ownerId']) && isValidWhiteboardElement(request.resource.data) && ownerIdUnchanged();
      allow update: if isAuthenticated() && isValidWhiteboardElement(request.resource.data) && ownerIdNotModified();
      allow delete: if isAuthenticated();
    }

    match /chatMessages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields(['id', 'text', 'senderId', 'timestamp', 'projectId']) && isValidChatMessage(request.resource.data) && senderIdUnchanged();
      allow update: if false; // Messages cannot be updated
      allow delete: if isAdmin(); // Only admins can delete messages
    }
    match /companyUsers/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && ownerIdUnchanged();
      allow update: if isAuthenticated() && ownerIdNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /projectMembers/{memberId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && ownerIdUnchanged();
      allow update: if isAuthenticated() && ownerIdNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /timeEntries/{entryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && ownerIdUnchanged();
      allow update: if isAuthenticated() && ownerIdNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /audioNotes/{noteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && ownerIdUnchanged();
      allow update: if isAuthenticated() && ownerIdNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /whiteboardExports/{exportId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && ownerIdUnchanged();
      allow update: if isAuthenticated() && ownerIdNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /slides/{slideId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && ownerIdUnchanged();
      allow update: if isAuthenticated() && ownerIdNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /contacts/{contactId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && ownerIdUnchanged();
      allow update: if isAuthenticated() && ownerIdNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /documents/{documentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && ownerIdUnchanged();
      allow update: if isAuthenticated() && ownerIdNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /knowledgeDocs/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && ownerIdUnchanged();
      allow update: if isAuthenticated() && ownerIdNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
